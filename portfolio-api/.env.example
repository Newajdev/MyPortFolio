# Neon: pooled URL for the app (hostname includes "-pooler")
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Neon: direct URL for migrations (same host without "-pooler")
DIRECT_URL="postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/neondb?sslmode=require"

PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
JWT_SECRET=change-this-to-a-long-random-secret

# Email notifications when someone submits the contact form (optional)
# Gmail: use an App Password — https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
# Where to send inbox alerts (defaults to Site Settings email in DB)
ADMIN_NOTIFY_EMAIL=your@gmail.com

# Local Docker alternative (see docker-compose.yml):
# DATABASE_URL="postgresql://portfolio:portfolio@localhost:5432/portfolio_db?schema=public"
# DIRECT_URL="postgresql://portfolio:portfolio@localhost:5432/portfolio_db?schema=public"
